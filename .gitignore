.DS_Store
.env
.env.*
!.env.example
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.idea/
.vscode/
node_modules/
dist/
build/
logs/
*.log
access_token.json
secrets/

# SQLite databases and WAL artifacts — runtime only, never commit
data/*.db
data/*.db-shm
data/*.db-wal

# Feature store — machine-generated, never commit
data/feature_store/

# Raw / processed data
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Backtest results and trained models — too large for git
backtest_results/*
!backtest_results/.gitkeep
models/*
!models/.gitkeep
