.DS_Store
.env
.env.*
!.env.example
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.idea/
.vscode/
node_modules/
dist/
build/
logs/
*.log
access_token.json
secrets/

# SQLite databases and WAL artifacts — runtime only, never commit
data/*.db
data/*.db-shm
data/*.db-wal

# Feature store — machine-generated, never commit
data/feature_store/

# Decision traces / paper-learning artifacts — runtime generated
data/decision_traces/

# Local assistant planning prompts, not deployable source
CLAUDE_*_PROMPT.md

# Raw / processed data
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Backtest results and trained models — too large for git
backtest_results/*
!backtest_results/.gitkeep
models/*
!models/.gitkeep

# FUSE filesystem artifacts left by Docker Desktop / network volume mounts
data/.fuse_hidden*

# SQLite backup snapshots (subdirectories aren't matched by data/*.db)
data/_sqlite_backup_*/

# Vite/PWA build debris
hft_frontend/dev-dist/
hft_frontend/vite.config.ts.timestamp-*.mjs

# Historical candle cache downloaded by scripts/train_return_forecaster.py
data/historical/

# Server deployment secrets — only the .example is committed
deploy/trading.env
