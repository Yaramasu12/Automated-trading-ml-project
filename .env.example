EXECUTION_MODE=BACKTEST
BROKER=ANGEL_ONE
LIVE_TRADING_ENABLED=false
INITIAL_CAPITAL=1000000
MAX_DRAWDOWN=0.10

# Runtime startup controls. Keep these false for local UI/dev to avoid broker
# rate-limit calls as soon as uvicorn boots; use the UI/API controls to start
# the agent or feed explicitly when needed.
AUTO_START_AGENT=false
AUTO_START_LIVE_FEED=false
AUTO_LOAD_INSTRUMENT_CACHE=true
PREMARKET_REFRESH_INSTRUMENTS=false
LIVE_FEED_DEFAULT_SYMBOLS=NIFTY,BANKNIFTY,FINNIFTY,SENSEX,RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,SBIN
LIVE_FEED_MAX_SYMBOLS=80
TRADING_API_BASE_URL=http://trading-api:8000
EMERGENCY_SQUARE_OFF_WEBHOOK_URL=

# ─── Phase 1–9: Advisory feature flags ───────────────────────────────────────
# These run in safe advisory/stub/classical modes unless configured otherwise.
ENABLE_AI_COUNCIL=true
ENABLE_NEURAL_LAB=true
ENABLE_QUANTUM_LAB=true
ENABLE_MARL_LAB=true
ENABLE_GOAL_GOVERNOR=true

# ─── Local Gemma-Compatible Model Gateway ────────────────────────────────────
# LLM agents NEVER submit orders. Advisory JSON only.
LOCAL_LLM_GATEWAY=disabled
LOCAL_LLM_RUNTIME=stub
LOCAL_LLM_PRIMARY_MODEL=gemma4-31b
LOCAL_LLM_FAST_MODEL=gemma4-e4b
LOCAL_LLM_COORDINATOR_MODEL=gemma4-26b-moe
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_TIMEOUT_SECONDS=15
LOCAL_LLM_MAX_OUTPUT_TOKENS=2048

# ─── Quantum Lab ─────────────────────────────────────────────────────────────
# Classical baseline always runs first. Quantum is experimental and optional.
QUANTUM_BACKEND=classical
QUANTUM_TIMEOUT_SECONDS=3
QUANTUM_MAX_CANDIDATES=12
QUANTUM_RISK_AVERSION=1.0
QUANTUM_CARDINALITY_LIMIT=4
QUANTUM_MIN_BASELINE_IMPROVEMENT=0.0
# IBM_QUANTUM_TOKEN=
# DWAVE_API_TOKEN=

# ─── Goal Governor ────────────────────────────────────────────────────────────
# ASPIRATIONAL TARGET ONLY — NOT A GUARANTEE. No profit is guaranteed.
# Goal pressure NEVER overrides risk, compliance, or kill switch.
YEARLY_PROFIT_TARGET=50000000
MAX_DAILY_LOSS=0.02
MAX_POSITION_PCT=0.05
MAX_MARGIN_UTILIZATION=0.60
LIVE_ORDER_CONFIRMATION=
ANGEL_ONE_API_KEY=
ANGEL_ONE_API_SECRET=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PIN=
ANGEL_ONE_TOTP_SECRET=
ANGEL_ONE_INSTRUMENT_MASTER_URL=https://margincalculator.angelone.in/OpenAPI_File/files/OpenAPIScripMaster.json
ANGEL_ONE_INSTRUMENT_CACHE_PATH=data/processed/angel_one_instruments.json
AWS_REGION=ap-south-1

# API authentication (REQUIRED to expose the API beyond 127.0.0.1).
# Generate a long random token, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# Send as `Authorization: Bearer <token>` on every mutating endpoint and as `?token=...`
# on the WebSocket. If unset and API_AUTH_REQUIRED is also unset/true, the API will
# return 503 on protected routes (fail-closed).
API_AUTH_TOKEN=
# Comma-separated list of allowed CORS origins. NEVER set to "*" with credentials.
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to false ONLY in local development to bypass auth (and only when API_AUTH_TOKEN is empty).
API_AUTH_REQUIRED=true
