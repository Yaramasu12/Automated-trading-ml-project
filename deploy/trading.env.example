# ── Production environment for the EC2 deployment ───────────────────────────
# Copy to /opt/trading/deploy/trading.env on the server and fill every <...>.
# NEVER commit the filled file. bootstrap.sh sources it before compose up.

# ── Execution posture: 24/7 paper trading ────────────────────────────────────
EXECUTION_MODE=PAPER
BROKER=ANGEL_ONE
LIVE_TRADING_ENABLED=false
AUTO_START_AGENT=true
AUTO_START_LIVE_FEED=true
AUTO_LOAD_INSTRUMENT_CACHE=true
AUTO_LOAD_MODELS=true
PREMARKET_REFRESH_INSTRUMENTS=true

# ── Capital & risk (keep in sync with what you ran locally) ──────────────────
INITIAL_CAPITAL=1000000
MAX_DRAWDOWN=0.10
MAX_DAILY_LOSS=0.02
MAX_POSITION_PCT=0.05
MAX_MARGIN_UTILIZATION=0.60

# ── Angel One credentials (fill on the server only) ──────────────────────────
ANGEL_ONE_API_KEY=<your-api-key>
ANGEL_ONE_API_SECRET=<your-api-secret>
ANGEL_ONE_CLIENT_CODE=<your-client-code>
ANGEL_ONE_PIN=<your-pin>
ANGEL_ONE_TOTP_SECRET=<your-totp-secret>

# ── API auth: REQUIRED on a server. Generate a fresh token: ──────────────────
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# (Do NOT reuse the token from your laptop era — it shipped in old JS bundles.)
API_AUTH_REQUIRED=true
API_AUTH_TOKEN=<paste-generated-token>
API_CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# ── Database (compose starts TimescaleDB; change the password) ───────────────
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=<pick-a-db-password>
DATABASE_URL=postgresql://trading:<pick-a-db-password>@timescaledb:5432/trading

# ── Phase 1: high-throughput on the VALIDATED vol edge ───────────────────────
# The short-vol structures (condor/put-spread/call-spread) are the only trade
# source with proven positive expectancy. Roll them continuously across the
# liquid index underlyings and both near expiries so the platform generates many
# edge-backed orders/day; each position auto-exits via its ExitPlan. Directional
# momentum stays OFF (AGENT_DIRECTIONAL_ENABLED unset) until the intraday model
# earns deployment — see scripts/train_intraday_forecaster.py.
SHORTVOL_CONTINUOUS=true
SHORTVOL_AUTO_UNDERLYINGS=NIFTY,BANKNIFTY,FINNIFTY,SENSEX
SHORTVOL_MAX_EXPIRIES=2
SHORTVOL_MAX_ENTRIES_PER_SCAN=5
AGENT_SCAN_UNDERLYINGS=NIFTY,BANKNIFTY,FINNIFTY,SENSEX
# 4-leg structures + their exits burn through the default 200/day cap quickly.
MAX_ORDERS_PER_DAY=500

# ── Feed & labs (same defaults as local) ─────────────────────────────────────
LIVE_FEED_DEFAULT_SYMBOLS=NIFTY,BANKNIFTY,FINNIFTY,SENSEX,RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,SBIN
LIVE_FEED_MAX_SYMBOLS=80
ENABLE_AI_COUNCIL=true
ENABLE_NEURAL_LAB=true
ENABLE_QUANTUM_LAB=true
ENABLE_MARL_LAB=true
ENABLE_GOAL_GOVERNOR=true
LOCAL_LLM_GATEWAY=disabled
LOCAL_LLM_RUNTIME=stub
QUANTUM_BACKEND=classical
AWS_REGION=ap-south-1

# ── Backups (deploy/backup.sh) ───────────────────────────────────────────────
BACKUP_S3_BUCKET=<your-backup-bucket-name>
